# ─────────────────────────────────────────────────
# RoadVision — Sample Environment Variables
# Copy this to .env and fill in real values
# ─────────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017/pothole_detection

# ── Node.js Server ───────────────────────────
PORT=5000
JWT_SECRET=supersecretjwtkey_replace_in_prod
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── Inference Service ────────────────────────
MODEL_PATH=./runs/detect/train2/weights/best.pt
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45
IMAGE_SIZE=640
STORAGE_DIR=./storage/detections
INFERENCE_PORT=8001

# ── Severity Tuning ─────────────────────────
SEVERITY_BBOX_WEIGHT=0.6
SEVERITY_CONF_WEIGHT=0.4
SEVERITY_HIGH_THRESHOLD=70
SEVERITY_MEDIUM_THRESHOLD=40

# ── Geolocation ─────────────────────────────
NOMINATIM_ENABLED=false
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── Complaint Service ───────────────────────
COMPLAINT_ADAPTER=mock
COMPLAINT_PORT=8002
COMPLAINT_MAX_RETRIES=3
COMPLAINT_RETRY_BACKOFF=2.0

# ── PG Portal (browser automation adapter) ──
# PGPORTAL_USERNAME=your_pgportal_username
# PGPORTAL_PASSWORD=your_pgportal_password
# PGPORTAL_URL=https://pgportal.gov.in

# ── Human-in-the-Loop ───────────────────────
HUMAN_PENDING_DIR=./pending-complaints

# ── Orchestrator ────────────────────────────
ORCHESTRATOR_PORT=8000
INFERENCE_SERVICE_URL=http://localhost:8001
COMPLAINT_SERVICE_URL=http://localhost:8002
REVERIFY_ENABLED=false
REVERIFY_CRON=0 */6 * * *
